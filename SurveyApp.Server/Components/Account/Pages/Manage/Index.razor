@page "/Account/Manage"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using System.Text.RegularExpressions
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using SurveyApp.Server.Data

@attribute [Authorize]

@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Личный кабинет</PageTitle>

@if (isLoading)
{
    <div class="survey-section-card">
        <p class="mb-0">Загрузка профиля...</p>
    </div>
}
else
{
    <div class="survey-editor-page">
        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="alert alert-success">@successMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <section class="survey-section-card">
            <div class="manage-profile-layout">
                <div class="manage-profile-photo-block">
                    @if (profile?.Photo is not null && !string.IsNullOrWhiteSpace(profile.PhotoContentType))
                    {
                        <img class="manage-profile-photo"
                             src="@GetPhotoSrc()"
                             alt="Фото профиля" />
                    }
                    else
                    {
                        <div class="manage-profile-photo manage-profile-photo-placeholder">
                            @GetInitials()
                        </div>
                    }

                    <div class="manage-profile-photo-actions">
                        <InputFile OnChange="HandlePhotoSelected"
                                   class="form-control"
                                   accept="image/*" />

                        <small class="text-muted">Максимальный размер файла: 2 МБ</small>

                        @if (profile?.Photo is not null)
                        {
                            <button type="button"
                                    class="btn btn-outline-danger btn-sm"
                                    @onclick="ConfirmAndRemovePhoto">
                                Удалить фото
                            </button>
                        }
                    </div>
                </div>

                <div class="manage-profile-form-block">
                    <EditForm Model="Input" OnValidSubmit="OnValidSubmitAsync" class="auth-form">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger mb-3" role="alert" />

                        <div class="survey-meta-grid">
                            <div class="survey-field survey-field-full">
                                <label for="username" class="form-label">Имя пользователя</label>
                                <input type="text"
                                       value="@username"
                                       id="username"
                                       class="form-control"
                                       disabled />
                            </div>

                            <div class="survey-field">
                                <label for="email" class="form-label">Электронная почта</label>
                                <input type="text"
                                       value="@email"
                                       id="email"
                                       class="form-control"
                                       disabled />
                            </div>

                            <div class="survey-field">
                                <label for="phone" class="form-label">Телефон</label>
                                <InputText @bind-Value="Input.PhoneNumber"
                                           id="phone"
                                           class="form-control"
                                           placeholder="+7XXXXXXXXXX" />
                                <ValidationMessage For="() => Input.PhoneNumber" class="text-danger" />
                            </div>

                            <div class="survey-field">
                                <label for="firstName" class="form-label">Имя</label>
                                <InputText @bind-Value="Input.FirstName"
                                           id="firstName"
                                           class="form-control"
                                           placeholder="Введите имя" />
                                <ValidationMessage For="() => Input.FirstName" class="text-danger" />
                            </div>

                            <div class="survey-field">
                                <label for="lastName" class="form-label">Фамилия</label>
                                <InputText @bind-Value="Input.LastName"
                                           id="lastName"
                                           class="form-control"
                                           placeholder="Введите фамилию" />
                                <ValidationMessage For="() => Input.LastName" class="text-danger" />
                            </div>

                            <div class="survey-field">
                                <label for="birthDate" class="form-label">Дата рождения</label>
                                <InputDate @bind-Value="Input.BirthDate"
                                           id="birthDate"
                                           class="form-control" />
                                <ValidationMessage For="() => Input.BirthDate" class="text-danger" />
                            </div>

                            <div class="survey-field">
                                <label for="gender" class="form-label">Пол</label>
                                <InputText @bind-Value="Input.Gender"
                                           id="gender"
                                           class="form-control"
                                           placeholder="Женский / Мужской" />
                                <ValidationMessage For="() => Input.Gender" class="text-danger" />
                            </div>

                            <div class="survey-field survey-field-full">
                                <label for="city" class="form-label">Город</label>
                                <InputText @bind-Value="Input.City"
                                           id="city"
                                           class="form-control"
                                           placeholder="Введите город" />
                                <ValidationMessage For="() => Input.City" class="text-danger" />
                            </div>
                        </div>

                        <div class="survey-bottom-actions survey-bottom-actions-inline mt-4">
                            <div class="survey-bottom-actions-left"></div>
                            <div class="survey-bottom-actions-center">
                                <button type="submit" class="btn btn-primary survey-save-btn">
                                    Сохранить изменения
                                </button>
                            </div>
                            <div class="survey-bottom-actions-right"></div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </section>
    </div>
}

@code {
    private const long MaxPhotoSize = 2 * 1024 * 1024;

    private ApplicationUser? user;
    private UserProfile? profile;

    private string? username;
    private string? email;
    private string? phoneNumber;

    private bool isLoading = true;
    private string? successMessage;
    private string? errorMessage;

    private InputModel Input { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        isLoading = true;
        errorMessage = null;
        successMessage = null;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUser = authState.User;

        if (currentUser.Identity?.IsAuthenticated != true)
        {
            NavigationManager.NavigateTo("/Account/Login", forceLoad: true);
            return;
        }

        var userId = UserManager.GetUserId(currentUser);

        user = await UserManager.Users
            .Include(u => u.UserProfile)
            .FirstOrDefaultAsync(u => u.Id == userId);

        if (user is null)
        {
            NavigationManager.NavigateTo("/Account/Login", forceLoad: true);
            return;
        }

        username = await UserManager.GetUserNameAsync(user);
        email = await UserManager.GetEmailAsync(user);
        phoneNumber = await UserManager.GetPhoneNumberAsync(user);

        profile = user.UserProfile;

        if (profile is null)
        {
            profile = new UserProfile
            {
                UserId = user.Id
            };

            DbContext.UserProfiles.Add(profile);
            await DbContext.SaveChangesAsync();

            user.UserProfile = profile;
        }

        Input.PhoneNumber = phoneNumber;
        Input.FirstName = profile.FirstName;
        Input.LastName = profile.LastName;
        Input.BirthDate = profile.BirthDate;
        Input.Gender = profile.Gender;
        Input.City = profile.City;

        isLoading = false;
    }

    private async Task HandlePhotoSelected(InputFileChangeEventArgs e)
    {
        try
        {
            errorMessage = null;
            successMessage = null;

            if (user is null || profile is null)
                return;

            var file = e.File;

            if (file.Size > MaxPhotoSize)
            {
                errorMessage = "Размер фотографии не должен превышать 2 МБ.";
                return;
            }

            if (!file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
            {
                errorMessage = "Можно загружать только изображения.";
                return;
            }

            using var stream = file.OpenReadStream(MaxPhotoSize);
            using var memoryStream = new MemoryStream();

            await stream.CopyToAsync(memoryStream);

            profile.Photo = memoryStream.ToArray();
            profile.PhotoContentType = file.ContentType;

            DbContext.UserProfiles.Update(profile);
            await DbContext.SaveChangesAsync();

            successMessage = "Фотография профиля сохранена.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка при загрузке фотографии: {ex.Message}";
        }
    }

    private async Task ConfirmAndRemovePhoto()
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            "Вы уверены, что хотите удалить фото профиля?");

        if (!confirmed)
            return;

        await RemovePhoto();
    }

    private async Task RemovePhoto()
    {
        try
        {
            errorMessage = null;
            successMessage = null;

            if (user is null || profile is null)
                return;

            profile.Photo = null;
            profile.PhotoContentType = null;

            DbContext.UserProfiles.Update(profile);
            await DbContext.SaveChangesAsync();

            successMessage = "Фотография профиля удалена.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка при удалении фотографии: {ex.Message}";
        }
    }

    private async Task OnValidSubmitAsync()
    {
        try
        {
            errorMessage = null;
            successMessage = null;

            if (user is null || profile is null)
                return;

            NormalizeInput();

            if (Input.PhoneNumber != phoneNumber)
            {
                var setPhoneResult = await UserManager.SetPhoneNumberAsync(user, Input.PhoneNumber);

                if (!setPhoneResult.Succeeded)
                {
                    errorMessage = "Ошибка: не удалось сохранить номер телефона.";
                    return;
                }

                phoneNumber = Input.PhoneNumber;
            }

            profile.FirstName = Input.FirstName;
            profile.LastName = Input.LastName;
            profile.BirthDate = Input.BirthDate;
            profile.Gender = Input.Gender;
            profile.City = Input.City;

            DbContext.UserProfiles.Update(profile);
            await DbContext.SaveChangesAsync();

            successMessage = "Профиль успешно обновлён.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка при сохранении профиля: {ex.Message}";
        }
    }

    private void NormalizeInput()
    {
        Input.PhoneNumber = NormalizeSpaces(Input.PhoneNumber);
        Input.FirstName = NormalizeSpaces(Input.FirstName);
        Input.LastName = NormalizeSpaces(Input.LastName);
        Input.Gender = NormalizeSpaces(Input.Gender);
        Input.City = NormalizeSpaces(Input.City);
    }

    private static string? NormalizeSpaces(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        return Regex.Replace(value.Trim(), @"\s+", " ");
    }

    private string? GetPhotoSrc()
    {
        if (profile?.Photo is null || string.IsNullOrWhiteSpace(profile.PhotoContentType))
            return null;

        return $"data:{profile.PhotoContentType};base64,{Convert.ToBase64String(profile.Photo)}";
    }

    private string GetInitials()
    {
        var first = string.IsNullOrWhiteSpace(Input.FirstName)
            ? string.Empty
            : Input.FirstName.Trim()[0].ToString().ToUpper();

        var last = string.IsNullOrWhiteSpace(Input.LastName)
            ? string.Empty
            : Input.LastName.Trim()[0].ToString().ToUpper();

        var initials = $"{first}{last}".Trim();

        return string.IsNullOrWhiteSpace(initials) ? "U" : initials;
    }

    private sealed class InputModel : IValidatableObject
    {
        [RegularExpression(@"^(\+7|8)\d{10}$", ErrorMessage = "Телефон должен быть в формате +7XXXXXXXXXX или 8XXXXXXXXXX.")]
        [Display(Name = "Телефон")]
        public string? PhoneNumber { get; set; }

        [StringLength(100, ErrorMessage = "Имя не должно превышать 100 символов.")]
        [RegularExpression(@"^[А-Яа-яЁёA-Za-z\- ]+$", ErrorMessage = "Имя может содержать только буквы, пробелы и дефис.")]
        public string? FirstName { get; set; }

        [StringLength(100, ErrorMessage = "Фамилия не должна превышать 100 символов.")]
        [RegularExpression(@"^[А-Яа-яЁёA-Za-z\- ]+$", ErrorMessage = "Фамилия может содержать только буквы, пробелы и дефис.")]
        public string? LastName { get; set; }

        public DateTime? BirthDate { get; set; }

        [StringLength(50, ErrorMessage = "Пол не должен превышать 50 символов.")]
        [RegularExpression(@"^[А-Яа-яЁёA-Za-z\- ]+$", ErrorMessage = "Пол может содержать только буквы, пробелы и дефис.")]
        public string? Gender { get; set; }

        [StringLength(100, ErrorMessage = "Город не должен превышать 100 символов.")]
        [RegularExpression(@"^[А-Яа-яЁёA-Za-z\- ]+$", ErrorMessage = "Город может содержать только буквы, пробелы и дефис.")]
        public string? City { get; set; }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (BirthDate.HasValue)
            {
                var today = DateTime.Today;

                if (BirthDate.Value.Date > today)
                {
                    yield return new ValidationResult(
                        "Дата рождения не может быть позже текущей даты.",
                        new[] { nameof(BirthDate) });
                }

                if (BirthDate.Value.Date < today.AddYears(-120))
                {
                    yield return new ValidationResult(
                        "Проверьте корректность даты рождения.",
                        new[] { nameof(BirthDate) });
                }
            }
        }
    }
}