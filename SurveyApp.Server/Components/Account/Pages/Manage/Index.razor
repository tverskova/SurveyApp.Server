@page "/Account/Manage"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@using SurveyApp.Server.Data

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityRedirectManager RedirectManager
@inject ApplicationDbContext DbContext

<PageTitle>Личный кабинет</PageTitle>

@if (isLoading)
{
    <div class="survey-section-card">
        <p class="mb-0">Загрузка профиля...</p>
    </div>
}
else
{
    <div class="survey-editor-page">
        
        <StatusMessage />

        <section class="survey-section-card">
            <div class="manage-profile-layout">
                <div class="manage-profile-photo-block">
                    @if (profile?.Photo is not null && !string.IsNullOrWhiteSpace(profile.PhotoContentType))
                    {
                        <img class="manage-profile-photo"
                             src="@GetPhotoSrc()"
                             alt="Фото профиля" />
                    }
                    else
                    {
                        <div class="manage-profile-photo manage-profile-photo-placeholder">
                            @(GetInitials())
                        </div>
                    }

                    <div class="manage-profile-photo-actions">
                        <InputFile OnChange="HandlePhotoSelected" class="form-control" accept="image/*" />
                        <small class="text-muted">Максимальный размер файла: 2 МБ</small>

                        @if (profile?.Photo is not null)
                        {
                            <button type="button"
                                    class="btn btn-outline-danger btn-sm"
                                    @onclick="RemovePhoto">
                                Удалить фото
                            </button>
                        }
                    </div>
                </div>

                <div class="manage-profile-form-block">
                    <EditForm Model="Input" FormName="profile" OnValidSubmit="OnValidSubmitAsync" method="post" class="auth-form">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger mb-3" role="alert" />

                        <div class="survey-meta-grid">
                            <div class="survey-field survey-field-full">
                                <label for="username" class="form-label">Имя пользователя</label>
                                <input type="text"
                                       value="@username"
                                       id="username"
                                       class="form-control"
                                       disabled />
                            </div>

                            <div class="survey-field">
                                <label for="Input.Email" class="form-label">Электронная почта</label>
                                <input type="text"
                                       value="@email"
                                       id="Input.Email"
                                       class="form-control"
                                       disabled />
                            </div>

                            <div class="survey-field">
                                <label for="Input.PhoneNumber" class="form-label">Телефон</label>
                                <InputText @bind-Value="Input.PhoneNumber"
                                           id="Input.PhoneNumber"
                                           class="form-control"
                                           placeholder="Введите номер телефона" />
                                <ValidationMessage For="() => Input.PhoneNumber" class="text-danger" />
                            </div>

                            <div class="survey-field">
                                <label for="Input.FirstName" class="form-label">Имя</label>
                                <InputText @bind-Value="Input.FirstName"
                                           id="Input.FirstName"
                                           class="form-control"
                                           placeholder="Введите имя" />
                                <ValidationMessage For="() => Input.FirstName" class="text-danger" />
                            </div>

                            <div class="survey-field">
                                <label for="Input.LastName" class="form-label">Фамилия</label>
                                <InputText @bind-Value="Input.LastName"
                                           id="Input.LastName"
                                           class="form-control"
                                           placeholder="Введите фамилию" />
                                <ValidationMessage For="() => Input.LastName" class="text-danger" />
                            </div>

                            <div class="survey-field">
                                <label for="Input.BirthDate" class="form-label">Дата рождения</label>
                                <InputDate @bind-Value="Input.BirthDate"
                                           id="Input.BirthDate"
                                           class="form-control" />
                                <ValidationMessage For="() => Input.BirthDate" class="text-danger" />
                            </div>

                            <div class="survey-field">
                                <label for="Input.Gender" class="form-label">Пол</label>
                                <InputText @bind-Value="Input.Gender"
                                           id="Input.Gender"
                                           class="form-control"
                                           placeholder="Например: Женский / Мужской" />
                                <ValidationMessage For="() => Input.Gender" class="text-danger" />
                            </div>

                            <div class="survey-field survey-field-full">
                                <label for="Input.City" class="form-label">Город</label>
                                <InputText @bind-Value="Input.City"
                                           id="Input.City"
                                           class="form-control"
                                           placeholder="Введите город" />
                                <ValidationMessage For="() => Input.City" class="text-danger" />
                            </div>
                        </div>

                        <div class="survey-bottom-actions survey-bottom-actions-inline mt-4">
                            <div class="survey-bottom-actions-left"></div>
                            <div class="survey-bottom-actions-center">
                                <button type="submit" class="btn btn-primary survey-save-btn">
                                    Сохранить изменения
                                </button>
                            </div>
                            <div class="survey-bottom-actions-right"></div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </section>
    </div>
}

@code {
    private const long MaxPhotoSize = 2 * 1024 * 1024;

    private ApplicationUser? user;
    private UserProfile? profile;
    private string? username;
    private string? email;
    private string? phoneNumber;
    private bool isLoading = true;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        Input ??= new();

        user = await UserManager.Users
            .Include(u => u.UserProfile)
            .FirstOrDefaultAsync(u => u.Id == UserManager.GetUserId(HttpContext.User));

        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        username = await UserManager.GetUserNameAsync(user);
        email = await UserManager.GetEmailAsync(user);
        phoneNumber = await UserManager.GetPhoneNumberAsync(user);

        profile = user.UserProfile;

        if (profile is null)
        {
            profile = new UserProfile
            {
                UserId = user.Id
            };

            DbContext.UserProfiles.Add(profile);
            await DbContext.SaveChangesAsync();
        }

        Input.PhoneNumber = phoneNumber;
        Input.FirstName = profile.FirstName;
        Input.LastName = profile.LastName;
        Input.BirthDate = profile.BirthDate;
        Input.Gender = profile.Gender;
        Input.City = profile.City;

        isLoading = false;
    }

    private async Task HandlePhotoSelected(InputFileChangeEventArgs e)
    {
        if (user is null || profile is null)
            return;

        var file = e.File;
        if (file is null)
            return;

        if (file.Size > MaxPhotoSize)
        {
            RedirectManager.RedirectToCurrentPageWithStatus("Ошибка: размер фотографии не должен превышать 2 МБ.", HttpContext);
            return;
        }

        using var stream = file.OpenReadStream(MaxPhotoSize);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);

        profile.Photo = memoryStream.ToArray();
        profile.PhotoContentType = file.ContentType;

        await DbContext.SaveChangesAsync();
        await SignInManager.RefreshSignInAsync(user);
        StateHasChanged();
    }

    private async Task RemovePhoto()
    {
        if (user is null || profile is null)
            return;

        profile.Photo = null;
        profile.PhotoContentType = null;

        await DbContext.SaveChangesAsync();
        await SignInManager.RefreshSignInAsync(user);
        StateHasChanged();
    }

    private async Task OnValidSubmitAsync()
    {
        if (user is null || profile is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        if (Input.PhoneNumber != phoneNumber)
        {
            var setPhoneResult = await UserManager.SetPhoneNumberAsync(user, Input.PhoneNumber);
            if (!setPhoneResult.Succeeded)
            {
                RedirectManager.RedirectToCurrentPageWithStatus("Ошибка: не удалось сохранить номер телефона.", HttpContext);
                return;
            }

            phoneNumber = Input.PhoneNumber;
        }

        profile.FirstName = Input.FirstName;
        profile.LastName = Input.LastName;
        profile.BirthDate = Input.BirthDate;
        profile.Gender = Input.Gender;
        profile.City = Input.City;

        await DbContext.SaveChangesAsync();
        await SignInManager.RefreshSignInAsync(user);

        RedirectManager.RedirectToCurrentPageWithStatus("Профиль успешно обновлён.", HttpContext);
    }

    private string? GetPhotoSrc()
    {
        if (profile?.Photo is null || string.IsNullOrWhiteSpace(profile.PhotoContentType))
            return null;

        return $"data:{profile.PhotoContentType};base64,{Convert.ToBase64String(profile.Photo)}";
    }

    private string GetInitials()
    {
        var first = string.IsNullOrWhiteSpace(Input.FirstName) ? "" : Input.FirstName.Trim()[0].ToString().ToUpper();
        var last = string.IsNullOrWhiteSpace(Input.LastName) ? "" : Input.LastName.Trim()[0].ToString().ToUpper();

        var initials = $"{first}{last}".Trim();
        return string.IsNullOrWhiteSpace(initials) ? "U" : initials;
    }

    private sealed class InputModel
    {
        [Phone(ErrorMessage = "Введите корректный номер телефона.")]
        [Display(Name = "Телефон")]
        public string? PhoneNumber { get; set; }

        [StringLength(100, ErrorMessage = "Имя не должно превышать 100 символов.")]
        public string? FirstName { get; set; }

        [StringLength(100, ErrorMessage = "Фамилия не должна превышать 100 символов.")]
        public string? LastName { get; set; }

        public DateTime? BirthDate { get; set; }

        [StringLength(50, ErrorMessage = "Пол не должен превышать 50 символов.")]
        public string? Gender { get; set; }

        [StringLength(100, ErrorMessage = "Город не должен превышать 100 символов.")]
        public string? City { get; set; }
    }
}