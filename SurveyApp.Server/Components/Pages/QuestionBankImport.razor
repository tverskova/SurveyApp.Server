@page "/admin/question-bank/import"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using SurveyApp.Server.DTOs.QuestionBank
@using SurveyApp.Server.Services.Interfaces
@inject IQuestionBankService QuestionBankService
@inject NavigationManager NavigationManager

@attribute [Authorize(Roles = "Admin")]

<PageTitle>Импорт в банк вопросов</PageTitle>

<div class="survey-editor-page">
    <div class="survey-page-header">
        <div>
            <h3 class="survey-page-title">Импорт в банк вопросов</h3>
            <p class="survey-page-subtitle">Загрузите Excel или XML и выберите вопросы для сохранения</p>
        </div>
    </div>

    <section class="survey-section-card">
        <div class="survey-section-header">
            <h4 class="survey-section-title">Параметры импорта</h4>
        </div>

        <div class="survey-meta-grid">
            <div class="survey-field">
                <label class="form-label">Тип файла</label>
                <select class="form-select" @bind="selectedImportType">
                    <option value="excel">Excel (.xlsx)</option>
                    <option value="xml">XML (.xml)</option>
                </select>
            </div>

            <div class="survey-field survey-field-full">
                <label class="form-label">Подсказка по формату</label>

                @if (selectedImportType == "excel")
                {
                    <div class="survey-format-hint">
                        <div class="survey-format-hint-title">Excel должен содержать колонки:</div>
                        <div class="survey-format-hint-text">
                            QuestionCode, Category, Text, QuestionType, IsRequired, HasCorrectAnswer, RatingMin, RatingMax, OptionText, OptionOrder, IsCorrect
                        </div>
                    </div>
                }
                else
                {
                    <div class="survey-format-hint">
                        <div class="survey-format-hint-title">XML должен содержать структуру:</div>
                        <div class="survey-format-hint-text">
                            Корневой элемент Questions, внутри элементы Question, внутри при необходимости Options → Option
                        </div>
                    </div>
                }
            </div>

            <div class="survey-field survey-field-full">
                <label class="form-label">Файл для импорта</label>
                <div class="question-image-upload">
                    <InputFile OnChange="OnFileSelected"
                               accept="@GetAccept()"
                               class="form-control" />

                    @if (selectedFile is not null)
                    {
                        <small class="text-muted">Выбран файл: @selectedFile.Name</small>
                    }
                </div>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success survey-bottom-alert">@successMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger survey-bottom-alert">@errorMessage</div>
    }

    <div class="survey-bottom-actions survey-bottom-actions-inline">
        <div class="survey-bottom-actions-left"></div>

        <div class="survey-bottom-actions-center">
            <button type="button"
                    class="btn btn-success survey-save-btn"
                    @onclick="ImportPreviewAsync"
                    disabled="@isImporting">
                @(isImporting ? "Чтение..." : "Импортировать")
            </button>
        </div>

        <div class="survey-bottom-actions-right"></div>
    </div>
</div>

@if (showPreviewModal)
{
    <div class="survey-modal-backdrop">
        <div class="survey-modal-window survey-modal-window-lg">
            <div class="survey-modal-header">
                <h4 class="mb-0">Предпросмотр импортируемых вопросов</h4>
                <button type="button" class="btn-close" @onclick="ClosePreviewModal"></button>
            </div>

            <div class="survey-modal-body">
                @if (previewItems.Count == 0)
                {
                    <p class="text-muted">Не удалось прочитать ни одного вопроса.</p>
                }
                else
                {
                    <div class="bank-select-all-wrap mb-3">
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="selectAllPreview"
                                   checked="@IsAllPreviewSelected"
                                   @onchange="ToggleSelectAllPreview" />
                            <label class="form-check-label" for="selectAllPreview">
                                Выбрать все
                            </label>
                        </div>
                        <div class="bank-select-hint">Отметьте, чтобы выбрать или снять выбор со всех импортируемых вопросов</div>
                    </div>

                    @foreach (var group in GroupedPreviewItems)
                    {
                        var category = group.Key;
                        var isExpanded = expandedPreviewCategories.Contains(category);

                        <div class="card mb-3 survey-bank-item-card">
                            <div class="card-body">
                                <button type="button"
                                        class="btn w-100 text-start p-0 border-0 bg-transparent"
                                        @onclick="() => TogglePreviewCategory(category)">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="fw-bold" style="width: 20px;">
                                                @(isExpanded ? "▼" : "▶")
                                            </span>

                                            <div>
                                                <h5 class="mb-1">@category</h5>
                                                <small class="text-muted">Вопросов: @group.Value.Count</small>
                                            </div>
                                        </div>
                                    </div>
                                </button>

                                @if (isExpanded)
                                {
                                    <div class="mt-3">
                                        <div class="bank-select-all-wrap mb-3">
                                            <div class="form-check">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       id="@($"selectCategory_{category.GetHashCode()}")"
                                                       checked="@IsAllPreviewCategorySelected(category)"
                                                       @onchange="e => TogglePreviewCategorySelection(category, e)" />
                                                <label class="form-check-label" for="@($"selectCategory_{category.GetHashCode()}")">
                                                    Выбрать все в категории
                                                </label>
                                            </div>
                                            <div class="bank-select-hint">Отметьте, чтобы выбрать или снять выбор со всех вопросов этой категории</div>
                                        </div>

                                        @foreach (var item in group.Value)
                                        {
                                            <div class="card mb-2 survey-bank-item-card">
                                                <div class="card-body py-2">
                                                    <div class="form-check">
                                                        <input class="form-check-input"
                                                               type="checkbox"
                                                               checked="@selectedPreviewIds.Contains(item.TempId)"
                                                               @onchange="e => TogglePreviewSelection(item.TempId, e.Value as bool? == true)"
                                                               id="@($"preview_{item.TempId}")" />

                                                        <label class="form-check-label w-100" for="@($"preview_{item.TempId}")">
                                                            <span class="fw-semibold d-block">@item.Text</span>
                                                            <span class="small text-muted d-block">
                                                                Тип: @GetQuestionTypeLabel(item.QuestionType)
                                                            </span>

                                                            @if (item.Options.Count > 0)
                                                            {
                                                                <span class="small text-muted d-block">
                                                                    Варианты:
                                                                    @string.Join(", ", item.Options.OrderBy(o => o.Order).Select(o => o.Text))
                                                                </span>
                                                            }
                                                        </label>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>

            <div class="survey-modal-footer">
                <button type="button" class="btn btn-outline-secondary" @onclick="ClosePreviewModal">
                    Отмена
                </button>

                <button type="button" class="btn btn-success" @onclick="OpenConfirmModal">
                    Сохранить выбранные
                </button>
            </div>
        </div>
    </div>
}

@if (showConfirmModal)
{
    <div class="survey-modal-backdrop">
        <div class="survey-modal-window survey-modal-window-md">
            <div class="survey-modal-header">
                <h4 class="mb-0">Подтверждение импорта</h4>
                <button type="button" class="btn-close" @onclick="CloseConfirmModal"></button>
            </div>

            <div class="survey-modal-body">
                @if (selectedPreviewItems.Count == 0)
                {
                    <p class="text-muted">Не выбрано ни одного вопроса.</p>
                }
                else
                {
                    <p>Будут импортированы следующие вопросы:</p>

                    <ol class="mb-3">
                        @foreach (var item in selectedPreviewItems)
                        {
                            <li>@item.Text</li>
                        }
                    </ol>
                }
            </div>

            <div class="survey-modal-footer">
                <button type="button" class="btn btn-outline-secondary" @onclick="CloseConfirmModal">
                    Назад
                </button>

                <button type="button" class="btn btn-success" @onclick="SaveSelectedAsync" disabled="@isSaving">
                    @(isSaving ? "Сохранение..." : "Подтвердить импорт")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private const long MaxFileSize = 5 * 1024 * 1024;

    private IBrowserFile? selectedFile;
    private string selectedImportType = "excel";

    private bool isImporting;
    private bool isSaving;

    private string? successMessage;
    private string? errorMessage;

    private bool showPreviewModal;
    private bool showConfirmModal;

    private List<ImportQuestionBankPreviewDto> previewItems = new();
    private HashSet<Guid> selectedPreviewIds = new();
    private List<ImportQuestionBankPreviewDto> selectedPreviewItems = new();

    private HashSet<string> expandedPreviewCategories = new();

    private Dictionary<string, List<ImportQuestionBankPreviewDto>> GroupedPreviewItems =>
        previewItems
            .GroupBy(i => string.IsNullOrWhiteSpace(i.Category) ? "Без категории" : i.Category!)
            .OrderBy(g => g.Key)
            .ToDictionary(
                g => g.Key,
                g => g.OrderBy(x => x.Text).ToList()
            );

    private bool IsAllPreviewSelected =>
        previewItems.Count > 0 &&
        previewItems.All(x => selectedPreviewIds.Contains(x.TempId));

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        successMessage = null;
        errorMessage = null;
    }

    private string GetAccept()
    {
        return selectedImportType == "excel" ? ".xlsx" : ".xml";
    }

    private async Task ImportPreviewAsync()
    {
        try
        {
            successMessage = null;
            errorMessage = null;

            if (selectedFile == null)
            {
                errorMessage = "Сначала выберите файл.";
                return;
            }

            isImporting = true;

            await using var stream = selectedFile.OpenReadStream(MaxFileSize);

            previewItems = selectedImportType == "excel"
                ? await QuestionBankService.PreviewImportFromExcelAsync(stream)
                : await QuestionBankService.PreviewImportFromXmlAsync(stream);

            selectedPreviewIds = previewItems.Select(x => x.TempId).ToHashSet();
            expandedPreviewCategories.Clear();
            showPreviewModal = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка импорта: {ex.Message}";
        }
        finally
        {
            isImporting = false;
        }
    }

    private void TogglePreviewSelection(Guid id, bool isSelected)
    {
        if (isSelected)
            selectedPreviewIds.Add(id);
        else
            selectedPreviewIds.Remove(id);
    }

    private void ToggleSelectAllPreview(ChangeEventArgs e)
    {
        var isChecked = e.Value as bool? == true;

        if (isChecked)
            selectedPreviewIds = previewItems.Select(x => x.TempId).ToHashSet();
        else
            selectedPreviewIds.Clear();
    }

    private void TogglePreviewCategory(string category)
    {
        if (expandedPreviewCategories.Contains(category))
            expandedPreviewCategories.Remove(category);
        else
            expandedPreviewCategories.Add(category);
    }

    private bool IsAllPreviewCategorySelected(string category)
    {
        var items = GroupedPreviewItems[category];
        return items.Count > 0 && items.All(x => selectedPreviewIds.Contains(x.TempId));
    }

    private void TogglePreviewCategorySelection(string category, ChangeEventArgs e)
    {
        var isChecked = e.Value as bool? == true;
        var ids = GroupedPreviewItems[category].Select(x => x.TempId).ToList();

        if (isChecked)
        {
            foreach (var id in ids)
                selectedPreviewIds.Add(id);
        }
        else
        {
            foreach (var id in ids)
                selectedPreviewIds.Remove(id);
        }
    }

    private void ClosePreviewModal()
    {
        showPreviewModal = false;
    }

    private void OpenConfirmModal()
    {
        selectedPreviewItems = previewItems
            .Where(x => selectedPreviewIds.Contains(x.TempId))
            .ToList();

        showConfirmModal = true;
    }

    private void CloseConfirmModal()
    {
        showConfirmModal = false;
    }

    private async Task SaveSelectedAsync()
    {
        try
        {
            isSaving = true;
            errorMessage = null;
            successMessage = null;

            var count = await QuestionBankService.SaveImportedQuestionsAsync(selectedPreviewItems);

            showConfirmModal = false;
            showPreviewModal = false;

            previewItems.Clear();
            selectedPreviewIds.Clear();
            selectedPreviewItems.Clear();
            selectedFile = null;
            expandedPreviewCategories.Clear();

            successMessage = $"Импорт завершён. Добавлено вопросов: {count}.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка сохранения: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private string GetQuestionTypeLabel(string type)
    {
        return type switch
        {
            "SingleChoice" => "Один вариант ответа",
            "MultipleChoice" => "Несколько вариантов ответа",
            "Text" => "Текстовый ответ",
            "Number" => "Числовой ответ",
            "Rating" => "Рейтинг",
            "YesNo" => "Да / Нет",
            _ => type
        };
    }
}