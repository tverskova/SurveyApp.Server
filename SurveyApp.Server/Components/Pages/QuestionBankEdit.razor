@page "/admin/question-bank/edit/{Id:int}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using SurveyApp.Server.DTOs.QuestionBank
@using SurveyApp.Server.Services.Interfaces
@inject IQuestionBankService QuestionBankService
@inject NavigationManager NavigationManager

@attribute [Authorize(Roles = "Admin")]

<PageTitle>Редактирование вопроса</PageTitle>

@if (isLoading)
{
    <p>Загрузка вопроса...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage) && model is null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (model is null)
{
    <div class="alert alert-warning">Вопрос не найден.</div>
}
else
{
    <div class="survey-editor-page">
        <div class="survey-page-header">
            <div>
                <h3 class="survey-page-title">Редактирование вопроса</h3>
                <p class="survey-page-subtitle">Измените вопрос и сохраните обновлённую версию в банке</p>
            </div>
        </div>

        <section class="survey-section-card">
            <div class="survey-section-header">
                <h4 class="survey-section-title">Основная информация</h4>
            </div>

            <div class="survey-meta-grid">
                <div class="survey-field survey-field-full">
                    <label class="form-label">Текст вопроса</label>
                    <textarea class="form-control" rows="4" @bind="model.Text" placeholder="Введите текст вопроса"></textarea>
                </div>

                <div class="survey-field survey-field-full">
                    <label class="form-label">Категория</label>
                    <input class="form-control"
                           @bind="model.Category"
                           placeholder="Например: География, История, Математика" />
                </div>

                <div class="survey-field survey-field-full">
                    <label class="form-label">Изображение</label>

                    @if (model.Image is not null)
                    {
                        <div class="question-image-block">
                            <div class="question-image-preview-wrap">
                                <img src="data:image/jpeg;base64,@Convert.ToBase64String(model.Image)"
                                     alt="Изображение вопроса"
                                     class="question-image-preview" />
                            </div>

                            <button type="button"
                                    class="btn btn-outline-danger btn-sm"
                                    @onclick="OpenRemoveImageConfirm">
                                Удалить изображение
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="question-image-upload">
                            <InputFile OnChange="HandleImage" class="form-control" />
                            <small class="text-muted">Максимальный размер файла: 2 МБ</small>
                        </div>
                    }
                </div>

                <div class="survey-field-full">
                    <div class="question-settings-row @(model.QuestionType == "Rating" ? "question-settings-row-rating" : "")">
                        <div class="survey-field">
                            <label class="form-label">Тип вопроса</label>
                            <select class="form-select"
                                    value="@model.QuestionType"
                                    @onchange="e => OnTypeChanged(e.Value?.ToString())">
                                <option value="">-- Выберите тип вопроса --</option>
                                <option value="SingleChoice">Один вариант ответа</option>
                                <option value="MultipleChoice">Несколько вариантов ответа</option>
                                <option value="Text">Текстовый ответ</option>
                                <option value="Number">Числовой ответ</option>
                                <option value="Rating">Рейтинг</option>
                                <option value="YesNo">Да / Нет</option>
                            </select>

                            @if (!string.IsNullOrWhiteSpace(model.QuestionType))
                            {
                                <div class="question-type-hint">
                                    @GetQuestionTypeDescription(model.QuestionType)
                                </div>
                            }
                        </div>

                        @if (SupportsCorrectAnswer(model.QuestionType))
                        {
                            <div class="survey-field survey-field-correct-answer">
                                <label class="form-label">&nbsp;</label>
                                <div class="form-check survey-check survey-check-inline">
                                    <input class="form-check-input" type="checkbox" @bind="model.HasCorrectAnswer" id="hasCorrectAnswer" />
                                    <label class="form-check-label" for="hasCorrectAnswer">
                                        Есть правильный ответ
                                    </label>
                                </div>
                            </div>
                        }

                        @if (model.QuestionType == "Rating")
                        {
                            <div class="survey-field survey-field-rating">
                                <label class="form-label">Минимум</label>
                                <input class="form-control rating-number-input" type="number" @bind="model.RatingMin" />
                            </div>

                            <div class="survey-field survey-field-rating">
                                <label class="form-label">Максимум</label>
                                <input class="form-control rating-number-input" type="number" @bind="model.RatingMax" />
                            </div>
                        }
                    </div>
                </div>

                <div class="survey-options-row survey-field-full">
                    <div class="form-check survey-check">
                        <input class="form-check-input" type="checkbox" @bind="model.IsRequired" id="isRequired" />
                        <label class="form-check-label" for="isRequired">
                            Обязательный вопрос
                        </label>
                    </div>
                </div>
            </div>
        </section>

        @if (RequiresOptions(model.QuestionType))
        {
            <section class="survey-section-card">
                <div class="question-options-header">
                    <h6 class="question-options-title">Варианты ответа</h6>

                    @if (model.QuestionType != "YesNo")
                    {
                        <button type="button"
                                class="btn btn-outline-primary btn-sm"
                                @onclick="AddOption">
                            Добавить вариант
                        </button>
                    }
                </div>

                @if (model.Options.Count == 0)
                {
                    <div class="question-options-empty">Нет вариантов ответа.</div>
                }

                @for (int i = 0; i < model.Options.Count; i++)
                {
                    var optionIndex = i;
                    var option = model.Options[optionIndex];

                    <div class="question-option-row @(model.HasCorrectAnswer ? "question-option-row-with-correct" : "question-option-row-no-correct")">
                        <div class="question-option-sort">
                            <div class="survey-order-controls option-order-controls-vertical">
                                @if (optionIndex > 0)
                                {
                                    <button type="button"
                                            class="btn btn-outline-secondary btn-sm order-arrow-btn"
                                            title="Поднять вариант"
                                            @onclick="() => MoveOptionUp(optionIndex)">
                                        ↑
                                    </button>
                                }

                                @if (optionIndex < model.Options.Count - 1)
                                {
                                    <button type="button"
                                            class="btn btn-outline-secondary btn-sm order-arrow-btn"
                                            title="Опустить вариант"
                                            @onclick="() => MoveOptionDown(optionIndex)">
                                        ↓
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="question-option-main">
                            <label class="form-label small-label">Текст варианта №@(optionIndex + 1)</label>
                            <input class="form-control"
                                   placeholder="Текст варианта"
                                   @bind="option.Text" />
                        </div>

                        @if (model.HasCorrectAnswer)
                        {
                            <div class="question-option-correct">
                                <label class="form-label small-label d-block">Правильный ответ</label>
                                <div class="form-check mt-2">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           @bind="option.IsCorrect"
                                           id="@($"correct_{optionIndex}")" />
                                    <label class="form-check-label" for="@($"correct_{optionIndex}")">
                                        Да
                                    </label>
                                </div>
                            </div>
                        }

                        <div class="question-option-actions">
                            <label class="form-label small-label d-block">&nbsp;</label>
                            <button type="button"
                                    class="btn btn-outline-danger w-100"
                                    @onclick="() => RemoveOption(optionIndex)"
                                    @onclick:preventDefault="true">
                                Удалить
                            </button>
                        </div>
                    </div>
                }
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert alert-danger survey-bottom-alert">@errorMessage</div>
        }

        <div class="survey-bottom-actions survey-bottom-actions-inline">
            <div class="survey-bottom-actions-left"></div>

            <div class="survey-bottom-actions-center">
                <button type="button"
                        class="btn btn-success survey-save-btn"
                        @onclick="Save"
                        disabled="@isSaving">
                    @(isSaving ? "Сохранение..." : "Сохранить")
                </button>
            </div>

            <div class="survey-bottom-actions-right"></div>
        </div>
    </div>
}

@if (showRemoveImageConfirmModal)
{
    <div class="survey-modal-backdrop">
        <div class="survey-modal-window survey-modal-window-md">
            <div class="survey-modal-header">
                <h4 class="mb-0">Удаление изображения</h4>
                <button type="button" class="btn-close" @onclick="CloseRemoveImageConfirm"></button>
            </div>

            <div class="survey-modal-body">
                <p class="mb-0">Вы действительно хотите удалить изображение вопроса?</p>
            </div>

            <div class="survey-modal-footer">
                <button type="button" class="btn btn-outline-secondary" @onclick="CloseRemoveImageConfirm">
                    Отмена
                </button>

                <button type="button" class="btn btn-danger" @onclick="ConfirmRemoveImage">
                    Удалить
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private const long MaxFileSize = 2 * 1024 * 1024;

    private CreateQuestionBankItemDto? model;
    private bool isLoading = true;
    private bool isSaving;
    private string? errorMessage;
    private bool showRemoveImageConfirmModal;

    protected override async Task OnInitializedAsync()
    {
        var item = await QuestionBankService.GetByIdAsync(Id);

        if (item == null)
        {
            errorMessage = "Вопрос не найден.";
            isLoading = false;
            return;
        }

        model = new CreateQuestionBankItemDto
        {
            Text = item.Text,
            Category = item.Category,
            QuestionType = item.QuestionType,
            IsRequired = item.IsRequired,
            HasCorrectAnswer = item.HasCorrectAnswer,
            RatingMin = item.RatingMin,
            RatingMax = item.RatingMax,
            Image = item.Image,
            Options = item.Options
                .OrderBy(o => o.Order)
                .Select(o => new CreateQuestionBankOptionDto
                {
                    Text = o.Text,
                    Order = o.Order,
                    IsCorrect = o.IsCorrect
                })
                .ToList()
        };

        isLoading = false;
    }

    private void AddOption()
    {
        if (model is null)
            return;

        model.Options.Add(new CreateQuestionBankOptionDto
        {
            Order = model.Options.Count + 1
        });
    }

    private void RemoveOption(int index)
    {
        if (model == null || index < 0 || index >= model.Options.Count)
            return;

        model.Options.RemoveAt(index);
        RecalculateOptionOrders();
    }

    private void MoveOptionUp(int index)
    {
        if (model == null || index <= 0 || index >= model.Options.Count)
            return;

        var item = model.Options[index];
        model.Options.RemoveAt(index);
        model.Options.Insert(index - 1, item);
        RecalculateOptionOrders();
    }

    private void MoveOptionDown(int index)
    {
        if (model == null || index < 0 || index >= model.Options.Count - 1)
            return;

        var item = model.Options[index];
        model.Options.RemoveAt(index);
        model.Options.Insert(index + 1, item);
        RecalculateOptionOrders();
    }

    private void RecalculateOptionOrders()
    {
        if (model is null)
            return;

        for (int i = 0; i < model.Options.Count; i++)
        {
            model.Options[i].Order = i + 1;
        }
    }

    private async Task HandleImage(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;

            if (file == null || model == null)
                return;

            if (file.Size > MaxFileSize)
            {
                errorMessage = "Размер изображения не должен превышать 2 МБ.";
                return;
            }

            using var stream = file.OpenReadStream(MaxFileSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            model.Image = ms.ToArray();
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка при загрузке изображения: {ex.Message}";
        }
    }

    private void OpenRemoveImageConfirm()
    {
        showRemoveImageConfirmModal = true;
    }

    private void CloseRemoveImageConfirm()
    {
        showRemoveImageConfirmModal = false;
    }

    private void ConfirmRemoveImage()
    {
        if (model is null)
            return;

        model.Image = null;
        showRemoveImageConfirmModal = false;
    }

    private void OnTypeChanged(string? type)
    {
        if (model == null)
            return;

        model.QuestionType = type ?? string.Empty;

        if (model.QuestionType == "YesNo")
        {
            model.Options.Clear();
            model.Options.Add(new CreateQuestionBankOptionDto { Text = "Да", Order = 1, IsCorrect = false });
            model.Options.Add(new CreateQuestionBankOptionDto { Text = "Нет", Order = 2, IsCorrect = false });
            model.RatingMin = null;
            model.RatingMax = null;
            return;
        }

        if (model.QuestionType == "SingleChoice" || model.QuestionType == "MultipleChoice")
        {
            model.Options.Clear();
            model.Options.Add(new CreateQuestionBankOptionDto { Order = 1 });
            model.Options.Add(new CreateQuestionBankOptionDto { Order = 2 });
            model.RatingMin = null;
            model.RatingMax = null;
            return;
        }

        if (model.QuestionType == "Rating")
        {
            model.Options.Clear();
            model.RatingMin = 1;
            model.RatingMax = 5;
            model.HasCorrectAnswer = false;
            return;
        }

        model.Options.Clear();
        model.RatingMin = null;
        model.RatingMax = null;
        model.HasCorrectAnswer = false;
    }

    private bool RequiresOptions(string type)
    {
        return type == "SingleChoice"
            || type == "MultipleChoice"
            || type == "YesNo";
    }

    private bool SupportsCorrectAnswer(string type)
    {
        return type == "SingleChoice"
            || type == "MultipleChoice"
            || type == "YesNo";
    }

    private string GetQuestionTypeDescription(string questionType)
    {
        return questionType switch
        {
            "SingleChoice" => "Один вариант ответа",
            "MultipleChoice" => "Несколько вариантов ответа",
            "Text" => "Текстовый ответ",
            "Number" => "Числовой ответ",
            "Rating" => "Рейтинг",
            "YesNo" => "Да / Нет",
            _ => string.Empty
        };
    }

    private async Task Save()
    {
        if (model == null)
            return;

        try
        {
            isSaving = true;
            errorMessage = null;

            if (string.IsNullOrWhiteSpace(model.Text))
            {
                errorMessage = "Введите текст вопроса.";
                return;
            }

            if (string.IsNullOrWhiteSpace(model.QuestionType))
            {
                errorMessage = "Выберите тип вопроса.";
                return;
            }

            if (model.QuestionType == "Rating")
            {
                if (!model.RatingMin.HasValue || !model.RatingMax.HasValue)
                {
                    errorMessage = "Для вопроса с рейтингом нужно указать минимум и максимум.";
                    return;
                }

                if (model.RatingMin >= model.RatingMax)
                {
                    errorMessage = "Минимум рейтинга должен быть меньше максимума.";
                    return;
                }
            }

            if (RequiresOptions(model.QuestionType))
            {
                if (model.QuestionType == "YesNo")
                {
                    if (model.Options.Count == 0)
                    {
                        model.Options.Add(new CreateQuestionBankOptionDto { Text = "Да", Order = 1, IsCorrect = false });
                        model.Options.Add(new CreateQuestionBankOptionDto { Text = "Нет", Order = 2, IsCorrect = false });
                    }
                    else if (model.Options.Count == 1)
                    {
                        model.Options[0].Text = "Да";
                        model.Options[0].Order = 1;
                        model.Options.Add(new CreateQuestionBankOptionDto { Text = "Нет", Order = 2, IsCorrect = false });
                    }
                    else
                    {
                        model.Options[0].Text = "Да";
                        model.Options[0].Order = 1;
                        model.Options[1].Text = "Нет";
                        model.Options[1].Order = 2;

                        while (model.Options.Count > 2)
                        {
                            model.Options.RemoveAt(model.Options.Count - 1);
                        }
                    }
                }
                else
                {
                    if (model.Options.Count < 2)
                    {
                        errorMessage = "Для вопросов с выбором должно быть минимум 2 варианта.";
                        return;
                    }

                    if (model.Options.Any(o => string.IsNullOrWhiteSpace(o.Text)))
                    {
                        errorMessage = "Все варианты ответа должны быть заполнены.";
                        return;
                    }
                }
            }

            if (model.HasCorrectAnswer)
            {
                if (model.QuestionType == "SingleChoice" || model.QuestionType == "YesNo")
                {
                    var correctCount = model.Options.Count(o => o.IsCorrect);

                    if (correctCount != 1)
                    {
                        errorMessage = "Для вопроса с одним правильным ответом нужно выбрать ровно один правильный вариант.";
                        return;
                    }
                }
                else if (model.QuestionType == "MultipleChoice")
                {
                    var correctCount = model.Options.Count(o => o.IsCorrect);

                    if (correctCount < 1)
                    {
                        errorMessage = "Для вопроса с несколькими правильными ответами нужно выбрать хотя бы один правильный вариант.";
                        return;
                    }
                }
            }

            await QuestionBankService.UpdateAsync(Id, model);
            NavigationManager.NavigateTo("/admin/question-bank");
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка при сохранении: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }
}