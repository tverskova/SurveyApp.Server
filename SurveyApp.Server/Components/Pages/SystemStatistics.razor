@page "/admin/statistics"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using SurveyApp.Server.DTOs.Statistics
@using SurveyApp.Server.Services.Interfaces
@inject IStatisticsService StatisticsService
@inject NavigationManager NavigationManager

@attribute [Authorize(Roles = "Admin")]

<PageTitle>Статистика системы</PageTitle>

<div class="survey-editor-page">
    <div class="survey-page-header">
        <div>
            <h3 class="survey-page-title">Статистика системы</h3>
            <p class="survey-page-subtitle">Общая статистика пользователей, опросов и прохождений</p>
        </div>
    </div>

    @if (isLoading)
    {
        <section class="survey-section-card">
            <p class="mb-0">Загрузка статистики...</p>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (statistics is null)
    {
        <div class="alert alert-warning">Статистика недоступна.</div>
    }
    else
    {
        <section class="statistics-summary-grid">
            <div class="statistics-summary-card">
                <div class="statistics-summary-label">Пользователи</div>
                <div class="statistics-summary-value">@statistics.TotalUsers</div>
            </div>

            <div class="statistics-summary-card">
                <div class="statistics-summary-label">Всего опросов</div>
                <div class="statistics-summary-value">@statistics.TotalSurveys</div>
            </div>

            <div class="statistics-summary-card">
                <div class="statistics-summary-label">Опубликованные</div>
                <div class="statistics-summary-value">@statistics.PublishedSurveys</div>
            </div>

            <div class="statistics-summary-card">
                <div class="statistics-summary-label">Всего прохождений</div>
                <div class="statistics-summary-value">@statistics.TotalResponses</div>
            </div>
        </section>

        <section class="survey-section-card">
            <div class="survey-section-header survey-section-header-between statistics-table-header">
                <div>
                    <h4 class="survey-section-title">Опросы</h4>
                    <p class="survey-section-subtitle">Просмотр статистики по каждому опросу</p>
                </div>

                <div class="search-input-wrap statistics-search-wrap">
                    <input class="form-control search-input-with-clear"
                           placeholder="Поиск по названию..."
                           @bind="searchText" />

                    @if (!string.IsNullOrWhiteSpace(searchText))
                    {
                        <button type="button"
                                class="search-clear-btn"
                                title="Очистить поиск"
                                @onclick="ClearSearch">
                            ✕
                        </button>
                    }
                </div>
            </div>

            @if (FilteredSurveys.Count == 0)
            {
                <div class="survey-empty-state">
                    <div class="survey-empty-title">Опросы не найдены</div>
                    <div class="survey-empty-text">Попробуйте изменить строку поиска.</div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table admin-table align-middle">
                        <thead>
                            <tr>
                                <th>Название</th>
                                <th>Статус</th>
                                <th>Прохождения</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var survey in FilteredSurveys)
                            {
                                <tr>
                                    <td>@survey.Title</td>
                                    <td>
                                        @if (survey.IsPublished)
                                        {
                                            <span class="statistics-status statistics-status-published">Опубликован</span>
                                        }
                                        else
                                        {
                                            <span class="statistics-status statistics-status-draft">Черновик</span>
                                        }
                                    </td>
                                    <td>@survey.ResponsesCount</td>
                                    <td>
                                        <button type="button"
                                                class="btn btn-success btn-sm"
                                                @onclick="@(() => OpenSurveyResults(survey.SurveyId))">
                                            Аналитика
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }
</div>

@code {
    private SystemStatisticsDto? statistics;
    private bool isLoading = true;
    private string? errorMessage;
    private string searchText = string.Empty;

    private List<SystemSurveyStatisticsItemDto> FilteredSurveys =>
        statistics?.Surveys
            .Where(s => string.IsNullOrWhiteSpace(searchText)
                || s.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            .ToList()
        ?? new();

    protected override async Task OnInitializedAsync()
    {
        await LoadStatistics();
    }

    private async Task LoadStatistics()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            statistics = await StatisticsService.GetSystemStatisticsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка при загрузке статистики: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ClearSearch()
    {
        searchText = string.Empty;
    }

    private void OpenSurveyResults(int surveyId)
    {
        NavigationManager.NavigateTo($"/admin/results/{surveyId}?from=system");
    }
}